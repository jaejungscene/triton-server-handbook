# =============================================================================
# Triton Inference Server — Environment Variables (Example)
# =============================================================================
# 이 파일을 복사하여 .env.dev / .env.staging / .env.prod 로 환경별 설정
# cp .env.example .env.dev
# =============================================================================

# ---------------------------------------------------------------------------
# Triton Server
# ---------------------------------------------------------------------------
TRITON_IMAGE=nvcr.io/nvidia/tritonserver:24.08-py3
TRITON_HTTP_PORT=8000
TRITON_GRPC_PORT=8001
TRITON_METRICS_PORT=8002

# ---------------------------------------------------------------------------
# Model Repository
# ---------------------------------------------------------------------------
MODEL_REPOSITORY_PATH=./model_repository

# Cloud Storage (S3/GCS/Azure — 사용 시 주석 해제)
# MODEL_REPOSITORY_PATH=s3://your-bucket/model_repository
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-northeast-2

# ---------------------------------------------------------------------------
# Response Cache
# ---------------------------------------------------------------------------
CACHE_TYPE=local
CACHE_SIZE=67108864

# Redis Cache (사용 시 주석 해제)
# CACHE_TYPE=redis
# REDIS_HOST=redis
# REDIS_PORT=6379

# ---------------------------------------------------------------------------
# TLS / SSL (사용 시 주석 해제)
# ---------------------------------------------------------------------------
# TLS_ENABLED=true
# TLS_GRPC_CERT=/certs/server.crt
# TLS_GRPC_KEY=/certs/server.key
# TLS_GRPC_ROOT_CERT=/certs/ca.crt
# TLS_HTTP_CERT=/certs/server.crt
# TLS_HTTP_KEY=/certs/server.key

# ---------------------------------------------------------------------------
# Tracing (OpenTelemetry)
# ---------------------------------------------------------------------------
TRACE_ENABLED=false
TRACE_MODE=opentelemetry
OTEL_COLLECTOR_URL=http://otel-collector:4318/v1/traces

# ---------------------------------------------------------------------------
# Container Registry
# ---------------------------------------------------------------------------
CONTAINER_REGISTRY=ghcr.io
CONTAINER_IMAGE_NAME=your-org/triton-inference-server
