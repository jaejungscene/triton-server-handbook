# =============================================================================
# Triton Inference Server - .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Model Repository (런타임 아티팩트 — CI/CD가 scripts/build.sh로 생성)
# ---------------------------------------------------------------------------
model_repository/*
!model_repository/.gitkeep

# ---------------------------------------------------------------------------
# Model Binaries (Git에 추적하지 않는 모델 파일)
# ---------------------------------------------------------------------------
*.plan
*.onnx
*.pt
*.pth
*.savedmodel
*.tflite
*.bin
*.engine
*.xgboost
*.lgbm
*.pkl
*.joblib

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# Environment / Secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example
!.env.dev
!.env.staging
!.env.prod

# TLS certificates (never commit real certs)
*.pem
*.key
*.crt
*.csr

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
docker-compose.override.yml

# ---------------------------------------------------------------------------
# Kubernetes
# ---------------------------------------------------------------------------
kubeconfig
*.kubeconfig

# ---------------------------------------------------------------------------
# Monitoring data
# ---------------------------------------------------------------------------
monitoring/prometheus/data/
monitoring/grafana/data/

# ---------------------------------------------------------------------------
# Test / Performance artifacts
# ---------------------------------------------------------------------------
tests/perf/results/
*.log
htmlcov/
.coverage
.pytest_cache/

# ---------------------------------------------------------------------------
# Trace output
# ---------------------------------------------------------------------------
*.trace.json
trace_output/
